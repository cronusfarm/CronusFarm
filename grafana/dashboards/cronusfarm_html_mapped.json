      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "options": {
        "mode": "html",
        "content": "<style>\n:root{\n  --g0:#040d07;--g1:#0a1a0f;--g2:#0f2415;--g3:#152e1a;\n  --accent:#2dff7a;--accent2:#00e5ff;--accent3:#ffb830;--warn:#ff6b35;--pu:#bb86fc;\n  --muted:#3a5c42;--text:#c8e6c9;--text2:#6b9c73;--text3:#3a5c42;\n  --border:rgba(45,255,122,.07);--border2:rgba(45,255,122,.16);\n  --card:rgba(10,26,15,.9);--glow:0 0 28px rgba(45,255,122,.07);\n  --fm:'DM Mono',monospace;--fb:'Noto Sans KR',system-ui,sans-serif;\n}\n\n/* Grafana 패널 내부에서만 HTML 레이아웃 재현 */\n.cf-wrap{position:relative;background:var(--g0);color:var(--text);font-family:var(--fb);padding:14px;border-radius:10px;overflow:hidden;border:1px solid var(--border)}\n.cf-wrap::before{content:'';position:absolute;inset:0;pointer-events:none;\n  background-image:linear-gradient(rgba(45,255,122,.022) 1px,transparent 1px),linear-gradient(90deg,rgba(45,255,122,.022) 1px,transparent 1px);\n  background-size:48px 48px;opacity:.7}\n.cf-wrap::after{content:'';position:absolute;inset:0;pointer-events:none;\n  background:radial-gradient(ellipse 55% 40% at 15% 15%,rgba(45,255,122,.04) 0%,transparent 70%),\n             radial-gradient(ellipse 45% 55% at 85% 85%,rgba(0,229,255,.025) 0%,transparent 70%)}\n\n.cf-top{position:relative;z-index:1;display:flex;align-items:center;gap:12px;margin-bottom:10px}\n.cf-logo{width:44px;height:44px;background:var(--accent);display:flex;align-items:center;justify-content:center;\n  clip-path:polygon(0 0,100% 0,82% 100%,0 100%);flex-shrink:0;font-size:18px}\n.cf-brand{display:flex;flex-direction:column}\n.cf-name{font-family:var(--fm);font-size:14px;font-weight:700;letter-spacing:.08em;color:var(--accent);text-transform:uppercase}\n.cf-sub{font-family:var(--fm);font-size:10px;color:var(--text2);letter-spacing:.12em;margin-top:2px}\n\n.cf-sec{position:relative;z-index:1;display:flex;align-items:center;gap:10px;margin:14px 0 10px}\n.cf-line{flex:1;height:1px;background:var(--border2)}\n.cf-sectl{font-family:var(--fm);font-size:10px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--text2);white-space:nowrap}\n.cf-bdg{font-family:var(--fm);font-size:9px;color:var(--text3);background:rgba(45,255,122,.04);\n  border:1px solid var(--border);padding:2px 6px;border-radius:3px;letter-spacing:.06em;white-space:nowrap}\n\n.cf-g{position:relative;z-index:1;display:grid;gap:7px}\n.cf-g6{grid-template-columns:repeat(6,1fr)}\n.cf-g4{grid-template-columns:repeat(4,1fr)}\n\n.cf-card{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:10px 12px;overflow:hidden}\n.cf-clbl{font-family:var(--fm);font-size:10px;color:var(--text3);letter-spacing:.14em;text-transform:uppercase;margin-bottom:6px;display:flex;justify-content:space-between;gap:8px}\n.cf-ctype{font-size:9px;background:rgba(45,255,122,.04);border:1px solid var(--border);color:var(--text3);padding:1px 6px;border-radius:4px;white-space:nowrap}\n.cf-val{font-family:var(--fm);font-size:22px;font-weight:500;line-height:1;color:var(--text)}\n.cf-vu{font-size:11px;color:var(--text2);margin-left:2px}\n.cf-bar{height:3px;background:rgba(45,255,122,.07);border-radius:2px;margin-top:7px;overflow:hidden}\n.cf-bf{height:100%;border-radius:2px}\n.cf-ok{color:var(--accent)}.cf-inf{color:var(--accent2)}.cf-wn{color:var(--accent3)}.cf-er{color:var(--warn)}\n\n@media(max-width:1200px){.cf-g6{grid-template-columns:repeat(3,1fr)}}\n@media(max-width:700px){.cf-g6,.cf-g4{grid-template-columns:repeat(2,1fr)}}\n</style>\n\n<div class=\"cf-wrap\">\n  <div class=\"cf-top\">\n    <div class=\"cf-logo\">🌿</div>\n    <div class=\"cf-brand\">\n      <div class=\"cf-name\">CronusFarm</div>\n      <div class=\"cf-sub\">ARTICHOKE SMART SYSTEM · LIVE</div>\n    </div>\n  </div>\n\n  <div class=\"cf-sec\"><div class=\"cf-line\"></div><div class=\"cf-sectl\">실시간 환경</div><div class=\"cf-bdg\">tele · last</div><div class=\"cf-line\"></div></div>\n  <div class=\"cf-g cf-g6\">\n    <div class=\"cf-card\"><div class=\"cf-clbl\">내부 온도 <span class=\"cf-ctype\">stat</span></div><div class=\"cf-val cf-ok\">Grafana 패널(아래)에서 값을 표시합니다</div><div class=\"cf-bar\"><div class=\"cf-bf\" style=\"width:40%;background:var(--accent)\"></div></div></div>\n    <div class=\"cf-card\"><div class=\"cf-clbl\">내부 습도 <span class=\"cf-ctype\">stat</span></div><div class=\"cf-val cf-ok\">—<span class=\"cf-vu\">%</span></div><div class=\"cf-bar\"><div class=\"cf-bf\" style=\"width:50%;background:var(--accent)\"></div></div></div>\n    <div class=\"cf-card\"><div class=\"cf-clbl\">pH <span class=\"cf-ctype\">gauge</span></div><div class=\"cf-val cf-ok\">—</div><div class=\"cf-bar\"><div class=\"cf-bf\" style=\"width:60%;background:var(--accent)\"></div></div></div>\n    <div class=\"cf-card\"><div class=\"cf-clbl\">EC <span class=\"cf-ctype\">gauge</span></div><div class=\"cf-val cf-wn\">—<span class=\"cf-vu\">mS/cm</span></div><div class=\"cf-bar\"><div class=\"cf-bf\" style=\"width:30%;background:var(--accent3)\"></div></div></div>\n    <div class=\"cf-card\"><div class=\"cf-clbl\">CO₂ <span class=\"cf-ctype\">stat</span></div><div class=\"cf-val cf-ok\">—<span class=\"cf-vu\">ppm</span></div><div class=\"cf-bar\"><div class=\"cf-bf\" style=\"width:45%;background:var(--accent)\"></div></div></div>\n    <div class=\"cf-card\"><div class=\"cf-clbl\">외부온도(KMA) <span class=\"cf-ctype\">api</span></div><div class=\"cf-val cf-inf\">(추후 tele.kma_temp)</div><div class=\"cf-bar\"><div class=\"cf-bf\" style=\"width:20%;background:var(--accent2)\"></div></div></div>\n  </div>\n\n  <div class=\"cf-sec\"><div class=\"cf-line\"></div><div class=\"cf-sectl\">장치 현황</div><div class=\"cf-bdg\">tele · state</div><div class=\"cf-line\"></div></div>\n  <div class=\"cf-g cf-g4\">\n    <div class=\"cf-card\"><div class=\"cf-clbl\">LED A1 <span class=\"cf-ctype\">state</span></div><div class=\"cf-val\">(아래 패널에서 맵핑)</div></div>\n    <div class=\"cf-card\"><div class=\"cf-clbl\">Pump C1 <span class=\"cf-ctype\">state</span></div><div class=\"cf-val\">(아래 패널에서 맵핑)</div></div>\n    <div class=\"cf-card\"><div class=\"cf-clbl\">Fan A1 <span class=\"cf-ctype\">state</span></div><div class=\"cf-val\">(아래 패널에서 맵핑)</div></div>\n    <div class=\"cf-card\"><div class=\"cf-clbl\">Fan B1 <span class=\"cf-ctype\">state</span></div><div class=\"cf-val\">(아래 패널에서 맵핑)</div></div>\n  </div>\n</div>"
      }
    },

