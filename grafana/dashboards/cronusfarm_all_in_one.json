{
  "uid": "cronusfarm-all-in-one",
  "title": "CronusFarm 올인원",
  "tags": [
    "cronusfarm",
    "all-in-one"
  ],
  "timezone": "Asia/Seoul",
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 3,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "zone",
        "label": "Zone",
        "hide": 0,
        "datasource": {
          "type": "influxdb",
          "uid": "efjwqrorrfxtsf"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "query": "import \"influxdata/influxdb/schema\"\n\nschema.tagValues(\n  bucket: \"CronusFarm\",\n  tag: \"zone\",\n  predicate: (r) => r._measurement == \"tele_db\",\n  start: -30d,\n)",
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "🌡️ 환경(tele_db: SQLite→Influx)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "gauge",
      "id": 2,
      "title": "pH",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 5
      },
      "datasource": {
        "type": "influxdb",
        "uid": "efjwqrorrfxtsf"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "efjwqrorrfxtsf"
          },
          "query": "from(bucket: \"CronusFarm\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r._measurement == \"tele_db\" and r._field == \"ph\")\n  |> filter(fn: (r) => r.zone =~ /${zone:regex}/)\n  |> last()"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 14,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
