{
  "uid": "cronusfarm-environment",
  "title": "CronusFarm 환경",
  "tags": ["cronusfarm", "environment"],
  "timezone": "Asia/Seoul",
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    { "type": "row", "id": 1, "title": "🧪 실시간 센서", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },
    {
      "type": "gauge",
      "id": 2,
      "title": "pH",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" }, "query": "from(bucket: \"CronusFarm\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r._measurement == \"tele\" and r._field == \"ph\")\n  |> last()" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "unit": "none", "min": 0, "max": 14, "decimals": 2, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 5.5 }, { "color": "green", "value": 6.0 }, { "color": "yellow", "value": 7.5 }, { "color": "red", "value": 8.0 }] } }, "overrides": [] }
    },
    {
      "type": "gauge",
      "id": 3,
      "title": "EC",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" }, "query": "from(bucket: \"CronusFarm\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r._measurement == \"tele\" and r._field == \"ec\")\n  |> last()" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "unit": "mS/cm", "min": 0, "max": 5, "decimals": 2, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 1.0 }, { "color": "green", "value": 1.5 }, { "color": "yellow", "value": 3.0 }, { "color": "red", "value": 4.0 }] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "온도",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" }, "query": "from(bucket: \"CronusFarm\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r._measurement == \"tele\" and r._field == \"temp\")\n  |> last()" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "value_and_name", "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "unit": "celsius", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 18 }, { "color": "yellow", "value": 28 }, { "color": "red", "value": 32 }] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "id": 5,
      "title": "습도",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" }, "query": "from(bucket: \"CronusFarm\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r._measurement == \"tele\" and r._field == \"humidity\")\n  |> last()" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "textMode": "value_and_name", "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 50 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 }] } }, "overrides": [] }
    },

    { "type": "row", "id": 10, "title": "📈 시계열", "gridPos": { "x": 0, "y": 6, "w": 24, "h": 1 }, "collapsed": false },
    {
      "type": "timeseries",
      "id": 11,
      "title": "온도 / 습도",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" }, "query": "from(bucket: \"CronusFarm\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"tele\")\n  |> filter(fn: (r) => r._field == \"temp\" or r._field == \"humidity\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")" }],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "pH / EC",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "efjwqrorrfxtsf" }, "query": "from(bucket: \"CronusFarm\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"tele\")\n  |> filter(fn: (r) => r._field == \"ph\" or r._field == \"ec\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")" }],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } }, "overrides": [] }
    }
  ]
}
