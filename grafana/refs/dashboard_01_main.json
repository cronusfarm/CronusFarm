{
  "__inputs": [
    { "name": "DS_INFLUXDB", "label": "InfluxDB", "type": "datasource", "pluginId": "influxdb", "pluginName": "InfluxDB" },
    { "name": "DS_SQLITE", "label": "SQLite", "type": "datasource", "pluginId": "frser-sqlite-datasource", "pluginName": "SQLite" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" }
  ],
  "title": "🌿 스마트팜 메인 대시보드",
  "uid": "smartfarm-main-v1",
  "description": "아티초크 스마트팜 전체 현황 - 환경/장치/알림 통합 뷰",
  "tags": ["smartfarm", "artichoke", "overview"],
  "timezone": "Asia/Seoul",
  "refresh": "30s",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "zone",
        "label": "구역",
        "type": "custom",
        "current": { "value": "zone_a", "text": "zone_a" },
        "options": [
          { "value": "zone_a", "text": "재배동 A" },
          { "value": "zone_b", "text": "재배동 B" },
          { "value": "$__all", "text": "전체" }
        ],
        "includeAll": true,
        "multi": false,
        "hide": 0
      },
      { "name": "bucket", "label": "Bucket", "type": "constant", "current": { "value": "smartfarm_raw" }, "hide": 2 }
    ]
  },
  "panels": [
    { "type": "row", "id": 1, "title": "🌡️ 실시간 환경", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },
    {
      "type": "stat",
      "id": 2,
      "title": "내부 온도",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensor_readings\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temperature\")\n  |> filter(fn: (r) => r[\"zone\"] == \"${zone}\")\n  |> last()"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 40,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 15 },
              { "color": "yellow", "value": 28 },
              { "color": "red", "value": 32 }
            ]
          },
          "mappings": []
        }
      }
    }
  ]
}
