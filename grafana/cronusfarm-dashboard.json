{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB-CronusFarm",
      "description": "",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "최근 센서값(선택)",
      "id": 1,
      "datasource": "${DS_INFLUXDB}",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "measurement": "sensor",
          "groupBy": [
            { "type": "time", "params": [ "10s" ] },
            { "type": "fill", "params": [ "null" ] }
          ],
          "select": [
            [
              { "type": "field", "params": [ "value" ] },
              { "type": "last", "params": [] }
            ]
          ],
          "tags": [
            { "key": "key", "operator": "=", "value": "$sensor_key" }
          ],
          "resultFormat": "time_series",
          "policy": "default"
        }
      ],
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] } }
    },
    {
      "type": "timeseries",
      "title": "센서 시계열(선택)",
      "id": 2,
      "datasource": "${DS_INFLUXDB}",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "measurement": "sensor",
          "groupBy": [
            { "type": "time", "params": [ "10s" ] },
            { "type": "fill", "params": [ "null" ] }
          ],
          "select": [
            [
              { "type": "field", "params": [ "value" ] },
              { "type": "mean", "params": [] }
            ]
          ],
          "tags": [
            { "key": "key", "operator": "=", "value": "$sensor_key" }
          ],
          "resultFormat": "time_series",
          "policy": "default"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LED/펌프 상태(0/1)",
      "id": 3,
      "datasource": "${DS_INFLUXDB}",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "measurement": "actuator",
          "groupBy": [
            { "type": "time", "params": [ "10s" ] },
            { "type": "fill", "params": [ "previous" ] }
          ],
          "select": [
            [
              { "type": "field", "params": [ "value" ] },
              { "type": "last", "params": [] }
            ]
          ],
          "tags": [
            { "key": "key", "operator": "=~", "value": "/^(led|pump)_/" }
          ],
          "resultFormat": "time_series",
          "policy": "default"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 37,
  "style": "dark",
  "tags": [ "cronusfarm" ],
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "sensor_key",
        "label": "센서 키",
        "datasource": "${DS_INFLUXDB}",
        "refresh": 2,
        "query": "SHOW TAG VALUES FROM \"sensor\" WITH KEY = \"key\"",
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CronusFarm — Sensors & Actuators",
  "uid": "cronusfarm-main",
  "version": 1
}

