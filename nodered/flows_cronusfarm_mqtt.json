    "z": "b1c5a1f1d7a2a3a1",
    "name": "tele → raw / S요약",
    "func": "const raw = (msg.payload ?? '').toString();\nconst m = raw.match(/S:\\s*([^|]+)/);\nconst short = m ? m[1].trim().replace(/\\s+/g, ' ') : '(S: 없음 — 아두이노 tele 미수신)';\nreturn [[{ payload: raw, topic: msg.topic }], [{ payload: short }]];",
