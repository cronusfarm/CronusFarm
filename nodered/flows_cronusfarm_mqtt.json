  {
    "id": "c2d5b8a8b3cc12a1",
    "type": "function",
    "z": "b1c5a1f1d7a2a3a1",
    "name": "cmd payload 만들기",
    "func": "// 펌웨어(CronusFarm.ino): key=value — pump_a1=0/1, on_pump_a1=초(1~)\n// ui_switch/ui_slider에 topic을 pump / onsec 으로 두고 구분합니다.\n\nconst devId = flow.get('deviceId') || 'cronusfarm-01';\nflow.set('deviceId', devId);\n\nconst t = (msg.topic || '').toString();\nif (t === 'pump') {\n    flow.set('pump', String(msg.payload));\n} else if (t === 'onsec') {\n    flow.set('onsec', String(msg.payload));\n}\n\nif (flow.get('pump') === undefined) flow.set('pump', '0');\nif (flow.get('onsec') === undefined) flow.set('onsec', '30');\n\nconst p = flow.get('pump');\nconst o = flow.get('onsec');\n\nmsg.topic = `cronusfarm/${devId}/cmd`;\nmsg.payload = `pump_a1=${p} on_pump_a1=${o}`;\nreturn msg;",
    "initialize": "flow.set('deviceId', flow.get('deviceId') || 'cronusfarm-01');\nflow.set('pump', flow.get('pump') || '0');\nflow.set('onsec', flow.get('onsec') || '30');\n",
    "outputs": 1,
    "noerr": 0,
    "finalize": "",
    "libs": [],
    "x": 400,
    "y": 150,
    "wires": [
      [
        "c9f2442f2d2fa2a1"
      ]
    ]
  },
