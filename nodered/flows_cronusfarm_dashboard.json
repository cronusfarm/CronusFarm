  {
    "id": "fn_cmd_merge_v2",
    "type": "function",
    "z": "tab_cronus_dash",
    "name": "cmd 만들기(v2)",
    "func": "const devId = flow.get('deviceId') || 'cronusfarm-01';\nflow.set('deviceId', devId);\n\nconst key = (msg.topic||'').toString();\nconst val = msg.payload;\nif (key) flow.set(key, val);\n\nconst keys = [\n  'led_a1','led_a2','pump_a1','pump_a2','led_b1','pump_b1','pump_b2',\n  'auto_led_a1','auto_led_a2','auto_pump_a1','auto_pump_a2','auto_led_b1','auto_pump_b1','auto_pump_b2',\n  'on_pump_a1','off_pump_a1','on_pump_a2','off_pump_a2','on_pump_b1','off_pump_b1','on_pump_b2','off_pump_b2'\n];\n\nconst parts=[];\nkeys.forEach(k=>{\n  const v = flow.get(k);\n  if (v === undefined || v === null) return;\n  parts.push(`${k}=${v}`);\n});\n\nmsg.topic = `cronusfarm/${devId}/cmd`;\nmsg.payload = parts.join(' ');\nreturn msg;",
    "outputs": 1,
    "x": 520,
    "y": 780,
    "wires": [
      [
        "mqtt_out_cmd",
        "ui_txt_cmd_preview"
      ]
    ]
  },
