  {
    "id": "fn_trim_uptime",
    "type": "function",
    "z": "tab_cronus_dash",
    "name": "uptime 정리",
    "func": "msg.payload = (msg.payload||'').toString().trim() || '-';\nreturn msg;",
    "outputs": 1,
    "x": 600,
    "y": 40,
    "wires": [
      [
        "ui_txt_uptime"
      ]
    ]
  },
  {
    "id": "fn_trim_ssid",
    "type": "function",
    "z": "tab_cronus_dash",
    "name": "ssid 정리",
    "func": "msg.payload = (msg.payload||'').toString().trim() || '(미연결)';\nreturn msg;",
    "outputs": 1,
    "x": 590,
    "y": 80,
    "wires": [
      [
        "ui_txt_ssid"
      ]
    ]
  },
  {
    "id": "fn_trim_ip",
    "type": "function",
    "z": "tab_cronus_dash",
    "name": "ip 정리",
    "func": "const s=(msg.payload||'').toString().trim();\nmsg.payload = (s.split(/\\s+/)[0]||'-');\nreturn msg;",
    "outputs": 1,
    "x": 580,
    "y": 120,
    "wires": [
      [
        "ui_txt_ip"
      ]
    ]
  },
  {
    "id": "fn_trim_nodered",
    "type": "function",
    "z": "tab_cronus_dash",
    "name": "nodered 정리",
    "func": "const s=(msg.payload||'').toString().trim();\nmsg.payload = (s==='active')?'정상':('비정상');\nmsg._ok = (s==='active');\nreturn msg;",
    "outputs": 1,
    "x": 610,
    "y": 160,
    "wires": [
      [
        "ui_txt_nodered",
        "ui_led_nodered"
      ]
    ]
  },
  {
    "id": "fn_trim_mosq",
