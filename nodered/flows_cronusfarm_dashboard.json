    "y": 360,
    "wires": []
  },
  {
    "id": "fn_seen_tele",
    "type": "function",
    "z": "tab_cronus_dash",
    "name": "tele 수신시각",
    "func": "flow.set('arduinoLastTeleMs', Date.now());\nreturn msg;",
    "outputs": 1,
    "x": 410,
    "y": 420,
    "wires": []
  },
  {
    "id": "fn_calc_online",
    "type": "function",
    "z": "tab_cronus_dash",
    "name": "online 계산",
    "func": "const now=Date.now();\nconst ls=flow.get('arduinoLastStatusMs')||0;\nconst lt=flow.get('arduinoLastTeleMs')||0;\nconst ok=((now-ls)<30000)||((now-lt)<5000);\nmsg._ok=ok;\nmsg.payload=ok?'정상':'미수신';\nmsg.statusAge=ls?Math.floor((now-ls)/1000):null;\nmsg.teleAge=lt?Math.floor((now-lt)/1000):null;\nreturn msg;",
    "outputs": 1,
    "x": 420,
    "y": 520,
    "wires": [
      [
        "ui_txt_arduino_state",
        "ui_led_arduino",
        "ui_tpl_conn_line"
      ]
    ]
  },
