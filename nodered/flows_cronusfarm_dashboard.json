  {
    "id": "fn_seen_status",
    "type": "function",
    "z": "tab_cronus_dash",
    "name": "status 수신시각",
    "func": "flow.set('arduinoLastStatusMs', Date.now());\nreturn msg;",
    "outputs": 1,
